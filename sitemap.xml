---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>{{ site.url }}/Intelligence/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  {% for cat in "Commercial Contracts,Employment,Privacy,Artificial Intelligence,Governance,Intellectual Property,Director Duties,Disputes" | split: "," %}
  <url>
    <loc>{{ site.url }}/Intelligence/category/{{ cat | slugify }}/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}

  {% for article in site.articles %}
  <url>
    <loc>{{ site.url }}{{ article.url }}</loc>
    <lastmod>{{ article.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

</urlset>
