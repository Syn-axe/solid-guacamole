---
layout: null
---
[
  {% for article in site.articles %}
  {
    "title": {{ article.title | jsonify }},
    "summary": {{ article.summary | jsonify }},
    "category": {{ article.category | jsonify }},
    "url": {{ article.url | jsonify }},
    "date": {{ article.date | date: "%-d %B %Y" | jsonify }},
    "read_time": {{ article.read_time | jsonify }},
    "risk": {{ article.risk | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
