<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page.title }} — On Retainer</title>
  <meta name="description" content="{{ page.summary }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --void:      #0A0A0A;
      --panel:     #111111;
      --border:    #1E1E1C;
      --parchment: #F2EDE4;
      --slate:     #8A8A80;
      --signal:    #C8B89A;
      --cat-color: {{ page.cat_color | default: "#C8B89A" }};
    }

    html { font-size: 16px; }

    body {
      background: var(--void);
      color: var(--parchment);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    main { flex: 1; }
    a { color: inherit; text-decoration: none; }

    /* NAV */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2.2rem 4rem;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .logo {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 0.82rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--parchment);
    }

    .nav-links { display: flex; gap: 2.5rem; list-style: none; }

    .nav-links a {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--slate);
      transition: color 0.25s;
    }

    .nav-links a:hover { color: var(--parchment); }

    /* ARTICLE HEADER */
    .article-header {
      max-width: 800px;
      margin: 0 auto;
      padding: 5rem 4rem 3rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--slate);
      opacity: 0.6;
      margin-bottom: 3rem;
      transition: opacity 0.2s;
    }

    .back-link:hover { opacity: 1; }

    .article-meta-top {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 1.8rem;
      flex-wrap: wrap;
    }

    .article-category {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cat-color);
      opacity: 0.8;
    }

    .article-meta-sep {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--slate);
      opacity: 0.3;
    }

    .article-meta-item {
      font-size: 0.68rem;
      color: var(--slate);
      opacity: 0.5;
      letter-spacing: 0.05em;
    }

    .risk-badge {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
      border: 1px solid var(--border);
      color: var(--slate);
      opacity: 0.6;
    }

    .cat-rule {
      width: 3rem;
      height: 2px;
      background: var(--cat-color);
      margin-bottom: 1.5rem;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1.15;
      color: var(--parchment);
      letter-spacing: -0.01em;
      margin-bottom: 1.2rem;
    }

    .article-standfirst {
      font-size: 1.05rem;
      color: var(--slate);
      line-height: 1.8;
      max-width: 600px;
      margin-bottom: 3rem;
    }

    .signal-rule { width: 100%; height: 1px; background: var(--border); }

    /* ARTICLE BODY — styles target rendered markdown output */
    .article-body { max-width: 800px; margin: 0 auto; padding: 3rem 4rem 5rem; }

    .article-body p {
      font-size: 1rem;
      color: var(--parchment);
      line-height: 1.9;
      margin-bottom: 1.6rem;
      opacity: 0.88;
    }

    .article-body h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 1.7rem;
      color: var(--parchment);
      margin: 3.5rem 0 1.2rem;
      line-height: 1.2;
      letter-spacing: -0.01em;
    }

    .article-body h3 {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--slate);
      margin: 2.5rem 0 1rem;
    }

    .article-body ul, .article-body ol { padding-left: 1.5rem; margin-bottom: 1.6rem; }

    .article-body li {
      font-size: 1rem;
      color: var(--parchment);
      line-height: 1.85;
      opacity: 0.88;
      margin-bottom: 0.5rem;
    }

    .article-body strong { font-weight: 500; color: var(--parchment); opacity: 1; }

    .article-body blockquote {
      border-left: 2px solid var(--cat-color);
      padding: 0.5rem 0 0.5rem 1.8rem;
      margin: 2.5rem 0;
    }

    .article-body blockquote p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-style: italic;
      opacity: 0.75;
      margin-bottom: 0;
    }

    /* FOOTER */
    footer {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      padding: 1.8rem 4rem 2.2rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
    }

    .disclaimer {
      font-size: 0.68rem;
      color: var(--slate);
      opacity: 0.5;
      line-height: 1.65;
      max-width: 680px;
    }

    .footer-mark {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--slate);
      opacity: 0.35;
      white-space: nowrap;
      flex-shrink: 0;
    }

    @media (max-width: 700px) {
      nav, footer { padding-left: 1.8rem; padding-right: 1.8rem; }
      .article-header, .article-body { padding-left: 1.8rem; padding-right: 1.8rem; }
      .article-header { padding-top: 3rem; }
      footer { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>
<body>

  <nav>
    <a class="logo" href="/">On Retainer</a>
    <ul class="nav-links">
      <li><a href="/Intelligence">Intelligence</a></li>
      <li><a href="https://linkedin.com/in/YOURHANDLE" target="_blank" rel="noopener">LinkedIn</a></li>
    </ul>
  </nav>

  <main>
    <div class="article-header">
      <a class="back-link" href="/Intelligence">← Legal Intelligence</a>

      <div class="cat-rule"></div>
      <div class="article-meta-top">
        <span class="article-category">{{ page.category }}</span>
        <span class="article-meta-sep"></span>
        <span class="article-meta-item">{{ page.read_time }}</span>
        <span class="article-meta-sep"></span>
        <span class="article-meta-item">{{ page.date | date: "%-d %B %Y" }}</span>
        <span class="article-meta-sep"></span>
        <span class="risk-badge">{{ page.risk }}</span>
      </div>

      <h1>{{ page.title }}</h1>
      <p class="article-standfirst">{{ page.summary }}</p>

      <div class="signal-rule"></div>
    </div>

    <div class="article-body">
      {{ content }}
    </div>
  </main>

  <footer>
    <p class="disclaimer">General information published on this site is for educational purposes only and does not constitute legal advice. No lawyer-client relationship is formed by reading this content. For advice specific to your circumstances, consult a qualified Australian legal practitioner.</p>
    <span class="footer-mark">QLD, Australia</span>
  </footer>

</body>
</html>
